go# ── Database (Supabase) ───────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → Database → Connection string

# Transaction pooler — used at runtime (serverless, short-lived connections)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — kept as fallback (may be IPv6-only on some networks)
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Session pooler — used by Prisma CLI for migrations (port 5432 via pooler host)
SESSION_POOLER_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ── Piston API ────────────────────────────────────────────────────────────────
PISTON_API_URL="https://emkc.org/api/v2/piston"
